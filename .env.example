# Environment Configuration Template

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DB_URL=sqlite:./data/uae.db
# DB_URL=postgres://user:password@localhost:5432/uae

# File Sandbox
TARGET_PATH=./sandbox

# Gemini API Keys (5 accounts for round-robin)
GEMINI_KEY_1=your-gemini-key-1
GEMINI_KEY_2=your-gemini-key-2
GEMINI_KEY_3=your-gemini-key-3
GEMINI_KEY_4=your-gemini-key-4
GEMINI_KEY_5=your-gemini-key-5

# GitHub Integration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USERNAME=your-github-username
GITHUB_ORGANIZATION=your-github-org

# Optional: External Services
SLACK_BOT_TOKEN=
OPENAI_API_KEY=
